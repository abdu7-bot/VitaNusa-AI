APP_ENV=development
APP_NAME=VitaNusa AI Brain

# Feedback review queue (token wajib diisi secara lokal untuk endpoint admin)
VITANUSA_ADMIN_TOKEN=
VITANUSA_FEEDBACK_MAX_RECORDS=1000
VITANUSA_FEEDBACK_RATE_LIMIT_REQUESTS=10
VITANUSA_FEEDBACK_RATE_LIMIT_WINDOW_SECONDS=60

# Optional: isi di backend/.env lokal bila backend nanti memakai layanan AI.
# Jangan commit API key asli.
OPENAI_API_KEY=

# Web Search Router (fondasi dummy; tidak melakukan koneksi jaringan)
WEB_SEARCH_MODE=mock
WEB_SEARCH_STRATEGY=aggregate
WEB_SEARCH_PROVIDERS=brave,duckduckgo,searxng
WEB_SEARCH_PROVIDER=brave
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_LANGUAGE=id
WEB_SEARCH_COUNTRY=ID
WEB_SEARCH_SAFE_SEARCH=true
WEB_SEARCH_PREVIEW_ENABLED=false
WEB_SEARCH_MOCK_SCENARIO=success

BRAVE_SEARCH_ENABLED=false
BRAVE_SEARCH_API_KEY=

DUCKDUCKGO_SEARCH_ENABLED=false
DUCKDUCKGO_BASE_URL=

SEARXNG_SEARCH_ENABLED=false
SEARXNG_BASE_URL=
SEARXNG_API_KEY=

# Local LLM Router (default aman; live hanya untuk provider loopback yang diaktifkan)
LOCAL_LLM_MODE=mock
LOCAL_LLM_STRATEGY=fallback
LOCAL_LLM_PROVIDERS=ollama,lmstudio,localai
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=
LOCAL_LLM_TIMEOUT_SECONDS=45
LOCAL_LLM_MAX_TOKENS=500
LOCAL_LLM_TEMPERATURE=0.2
LOCAL_LLM_PREVIEW_ENABLED=false
LOCAL_LLM_ASK_ENABLED=false
LOCAL_LLM_MOCK_SCENARIO=success

OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434

LM_STUDIO_ENABLED=false
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1

LOCALAI_ENABLED=false
LOCALAI_BASE_URL=http://127.0.0.1:8080/v1
