rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasValidAdminRole(adminData) {
      return adminData.role == "owner"
        || adminData.role == "admin";
    }

    function isActiveAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == "active"
        && hasValidAdminRole(
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data
        );
    }

    function isActiveOwner() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.status == "active"
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "owner";
    }

    function isOwnAdminDocument(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isOwnUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isValidAdminDocument(adminData) {
      return adminData.keys().hasAll(["email", "role", "status"])
        && adminData.keys().hasOnly(["email", "role", "status"])
        && adminData.email is string
        && hasValidAdminRole(adminData)
        && (adminData.status == "active" || adminData.status == "inactive");
    }

    function keepsOwnerSelfActive(uid) {
      return request.auth.uid != uid
        || (request.resource.data.role == "owner"
          && request.resource.data.status == "active");
    }

    function isValidVitaCheckCategoryList(categoryIds) {
      return categoryIds is list
        && categoryIds.size() <= 4
        && categoryIds.hasOnly([
          "tidur",
          "air",
          "makan",
          "gerak",
          "pencernaan",
          "energi",
          "stres",
          "literasi"
        ]);
    }

    function isSafeVitaCheckRecommendationSlug(slug) {
      return slug is string
        && slug.size() >= 1
        && slug.size() <= 120
        && slug.matches("^[a-z0-9]+(-[a-z0-9]+)*$");
    }

    function isValidVitaCheckRecommendationSlugs(slugs) {
      return slugs is list
        && slugs.size() <= 3
        && (slugs.size() < 1 || isSafeVitaCheckRecommendationSlug(slugs[0]))
        && (slugs.size() < 2 || isSafeVitaCheckRecommendationSlug(slugs[1]))
        && (slugs.size() < 3 || isSafeVitaCheckRecommendationSlug(slugs[2]));
    }

    function isValidVitaCheckHistory(historyData) {
      return historyData.keys().hasAll([
          "version",
          "score",
          "resultBand",
          "focusIds",
          "attentionIds",
          "recommendationSlugs",
          "source",
          "createdAt"
        ])
        && historyData.keys().hasOnly([
          "version",
          "score",
          "resultBand",
          "focusIds",
          "attentionIds",
          "recommendationSlugs",
          "source",
          "createdAt"
        ])
        && historyData.version is int
        && historyData.version == 2
        && historyData.score is int
        && historyData.score >= 0
        && historyData.score <= 100
        && (historyData.resultBand == "strong"
          || historyData.resultBand == "medium"
          || historyData.resultBand == "low")
        && isValidVitaCheckCategoryList(historyData.focusIds)
        && isValidVitaCheckCategoryList(historyData.attentionIds)
        && isValidVitaCheckRecommendationSlugs(historyData.recommendationSlugs)
        && historyData.source == "vitacheck-v2"
        && historyData.createdAt is timestamp
        && historyData.createdAt == request.time;
    }

    function isPublished() {
      return resource.data.status == "published";
    }

    function isPublicMedia() {
      return resource.data.status == "active"
        && resource.data.visibility == "public";
    }

    match /admins/{uid} {
      allow get: if isOwnAdminDocument(uid) || isActiveOwner();
      allow list: if isActiveOwner();
      allow create: if isActiveOwner()
        && isValidAdminDocument(request.resource.data);
      allow update: if isActiveOwner()
        && isValidAdminDocument(request.resource.data)
        && keepsOwnerSelfActive(uid);
      allow delete: if isActiveOwner()
        && request.auth.uid != uid;
    }

    match /users/{uid}/vitaCheckHistory/{resultId} {
      allow get, list: if isOwnUser(uid);
      allow create: if isOwnUser(uid)
        && isValidVitaCheckHistory(request.resource.data);
      allow update: if false;
      allow delete: if isOwnUser(uid);
    }

    match /articles/{articleId} {
      allow get, list: if isPublished() || isActiveAdmin();
      allow create, update, delete: if isActiveAdmin();
    }

    match /comics/{comicId} {
      allow get, list: if isPublished();
      allow create, update, delete: if isActiveAdmin();

      match /panels/{panelId} {
        allow get, list: if isPublished();
        allow create, update, delete: if isActiveAdmin();
      }
    }

    match /comicPanels/{panelId} {
      allow get, list: if isPublished();
      allow create, update, delete: if isActiveAdmin();
    }

    match /products/{productId} {
      allow get, list: if isPublished();
      allow create, update, delete: if isActiveAdmin();
    }

    match /faqs/{faqId} {
      allow get, list: if isPublished();
      allow create, update, delete: if isActiveAdmin();
    }

    match /nusaKnowledge/{knowledgeId} {
      allow get, list: if resource.data.status == "published" || isActiveAdmin();
      allow create, update, delete: if isActiveAdmin();
    }

    match /siteSettings/public {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isActiveAdmin();
    }

    match /siteSettings/{settingId} {
      allow get, list: if isActiveAdmin();
      allow create, update, delete: if isActiveAdmin();
    }

    match /mediaIndex/{mediaId} {
      allow get, list: if isPublicMedia();
      allow create, update, delete: if isActiveAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
