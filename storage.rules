rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isActiveAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.status == "active";
    }

    function isAllowedContentType() {
      return request.resource.contentType.matches("image/(png|jpeg|webp|gif|svg\\+xml)")
        || request.resource.contentType == "application/pdf";
    }

    function isAllowedArticleBannerType() {
      return request.resource.contentType.matches("image/(png|jpeg|webp)");
    }

    function isPublicFile() {
      return resource.metadata.visibility == "public";
    }

    function isValidPublicUpload() {
      return request.resource.size < 15 * 1024 * 1024
        && isAllowedContentType()
        && request.resource.metadata.visibility == "public";
    }

    function isValidArticleBannerUpload() {
      return request.resource.size <= 2 * 1024 * 1024
        && isAllowedArticleBannerType()
        && request.resource.metadata.visibility == "public"
        && request.resource.metadata.category == "article-banner";
    }

    match /article-banners/{articleSlug}/{fileName} {
      allow read: if isPublicFile();
      allow create, update: if isActiveAdmin() && isValidArticleBannerUpload();
      allow delete: if isActiveAdmin();
    }

    match /public/{filePath=**} {
      allow read: if isPublicFile();
      allow create, update: if isActiveAdmin() && isValidPublicUpload();
      allow delete: if isActiveAdmin();
    }

    match /images/public/{filePath=**} {
      allow read: if isPublicFile();
      allow create, update: if isActiveAdmin() && isValidPublicUpload();
      allow delete: if isActiveAdmin();
    }

    match /documents/public/{filePath=**} {
      allow read: if isPublicFile();
      allow create, update: if isActiveAdmin() && isValidPublicUpload();
      allow delete: if isActiveAdmin();
    }

    match /articles/public/{filePath=**} {
      allow read: if isPublicFile();
      allow create, update: if isActiveAdmin() && isValidPublicUpload();
      allow delete: if isActiveAdmin();
    }

    match /comics/public/{filePath=**} {
      allow read: if isPublicFile();
      allow create, update: if isActiveAdmin() && isValidPublicUpload();
      allow delete: if isActiveAdmin();
    }

    match /products/public/{filePath=**} {
      allow read: if isPublicFile();
      allow create, update: if isActiveAdmin() && isValidPublicUpload();
      allow delete: if isActiveAdmin();
    }

    match /{filePath=**} {
      allow read, write: if false;
    }
  }
}
