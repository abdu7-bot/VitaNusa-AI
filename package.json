{
  "name": "vitanusa-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VitaNusa AI frontend workflow for static website and Nusa AI integration.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "check": "npm run build",
    "test:admin-auth": "node --test tests/admin-access.test.mjs",
    "test:admin-management": "node --test tests/admin-management.test.mjs",
    "test:user-auth": "node --test tests/user-auth.test.mjs",
    "test:vitacheck-history": "node --test tests/vitacheck-history.test.mjs",
    "test:pwa-manifest": "node --test tests/pwa-manifest.test.mjs",
    "test:pwa-install": "node --test tests/pwa-install.test.mjs",
    "test:nusa-agent": "node --test tests/nusa-agent.test.mjs",
    "test:share-target": "node --test tests/share-target.test.mjs",
    "test:service-worker": "node --test tests/service-worker.test.mjs",
    "test:android-pwa": "node --test tests/pwa-manifest.test.mjs tests/pwa-install.test.mjs tests/nusa-agent.test.mjs tests/share-target.test.mjs tests/service-worker.test.mjs",
    "test:mandiri:shell": "node --test tests/mandiri/feature-flags.test.mjs tests/mandiri/app-shell.test.mjs tests/mandiri/offline-status.test.mjs tests/mandiri/shell/dashboard.test.mjs",
    "test:mandiri:domain": "node --test tests/mandiri/domain/*.test.mjs",
    "test:mandiri:storage": "node --test tests/mandiri/storage/*.test.mjs",
    "test:mandiri:repositories": "node --test tests/mandiri/repositories/*.test.mjs",
    "test:mandiri:services": "node --test tests/mandiri/services/*.test.mjs",
    "test:mandiri:workspace-ui": "node --test tests/mandiri/shell/workspace-panel.test.mjs",
    "test:mandiri:backup": "node --test tests/mandiri/export/*.test.mjs",
    "test:mandiri:security": "node --test tests/mandiri/security/*.test.mjs",
    "test:mandiri:recovery-ui": "node --test tests/mandiri/shell/backup-panel.test.mjs tests/mandiri/shell/recovery-page.test.mjs",
    "test:mandiri:learning-domain": "node --test tests/mandiri/learning/*.test.mjs",
    "check:mandiri:learning-content": "node scripts/mandiri/learning/verify-learning-packages.mjs",
    "review:mandiri:learning-content": "node scripts/mandiri/learning/print-content-review.mjs",
    "test:mandiri:learning-content": "node --test tests/mandiri/learning-content/*.test.mjs",
    "test:mandiri": "npm run test:mandiri:shell && npm run test:mandiri:domain && npm run test:mandiri:storage && npm run test:mandiri:repositories && npm run test:mandiri:services && npm run test:mandiri:workspace-ui && npm run test:mandiri:backup && npm run test:mandiri:security && npm run test:mandiri:recovery-ui && npm run test:mandiri:learning-domain && npm run test:mandiri:learning-content",
    "test:firestore-rules": "firebase emulators:exec --project demo-vitanusa-rules --only firestore \"node --test tests/firestore-rules.test.mjs\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "5.0.1",
    "fake-indexeddb": "6.2.5",
    "firebase": "12.16.0",
    "firebase-tools": "15.23.0",
    "vite": "^5.4.0"
  }
}
